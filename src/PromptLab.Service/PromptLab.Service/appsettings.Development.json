{
  "Sql": {
    "ConnectionString": "Server=.;Database=PromptLab.DB;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "Cache": {
    "TagsTtlSeconds": 120,
    "PromptSearchTtlSeconds": 30,
    "ProvidersTtlSeconds": 120
  },
  "Ai": {
    "DefaultProvider": "simulated",
    "EnabledProviders": [ "simulated", "openai", "claude", "gemini" ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
