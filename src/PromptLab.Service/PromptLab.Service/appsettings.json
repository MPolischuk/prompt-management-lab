{
  "Sql": {
    "ConnectionString": "Server=localhost;Database=PromptLab;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "Cache": {
    "TagsTtlSeconds": 300,
    "PromptSearchTtlSeconds": 60,
    "ProvidersTtlSeconds": 300
  },
  "Ai": {
    "DefaultProvider": "simulated",
    "EnabledProviders": [ "simulated", "openai", "anthropic", "google" ],
    "Models": [
      {
        "Id": "simulated-default",
        "Provider": "simulated",
        "DisplayName": "Simulated Default",
        "Enabled": true,
        "DefaultTemperature": 0.7,
        "DefaultMaxTokens": 400,
        "DefaultTopP": 1.0
      },
      {
        "Id": "gpt-5.5",
        "Provider": "openai",
        "DisplayName": "GPT-5.5",
        "Enabled": false
      },
      {
        "Id": "claude-sonnet",
        "Provider": "anthropic",
        "DisplayName": "Claude Sonnet",
        "Enabled": false
      },
      {
        "Id": "gemini-2.5-pro",
        "Provider": "google",
        "DisplayName": "Gemini 2.5 Pro",
        "Enabled": false
      }
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
