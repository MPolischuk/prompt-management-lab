{
  "Sql": {
    "ConnectionString": "Server=localhost;Database=PromptLab;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "Cache": {
    "TagsTtlSeconds": 300,
    "PromptSearchTtlSeconds": 60,
    "ProvidersTtlSeconds": 300
  },
  "Ai": {
    "DefaultProvider": "simulated",
    "EnabledProviders": [ "simulated", "openai", "claude", "gemini" ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
